#!/usr/bin/env bash
set -euo pipefail

# CC Switch CLI Wrapper for dinotty plugin
# Delegates to cc-switch CLI, translating between plugin API and cc-switch formats
#
# Usage: cc-switch <command> [args...]

# Check if cc-switch CLI is available
CC_SWITCH_BIN=""
if command -v cc-switch &>/dev/null; then
    CC_SWITCH_BIN="cc-switch"
fi

# cc-switch uses ~/.claude/cc_auto_switch_setting.json for storage
CC_SWITCH_CONFIG="$HOME/.claude/cc_auto_switch_setting.json"
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
DATA_DIR="$HOME/.dinotty/plugin-data/cc-switch"
STATS_FILE="$DATA_DIR/stats.json"

# Write/overwrite a provider entry directly into CC_SWITCH_CONFIG using jq.
# Does not require cc-switch binary. Args: alias name token url model haiku sonnet opus
_write_entry() {
    local alias="$1" name="$2" token="$3" url="$4" model="$5" haiku="$6" sonnet="$7" opus="$8"
    mkdir -p "$(dirname "$CC_SWITCH_CONFIG")"
    [ ! -f "$CC_SWITCH_CONFIG" ] && echo '{"configurations":{}}' > "$CC_SWITCH_CONFIG"

    local entry
    entry=$(jq -n \
        --arg name "$([ -n "$name" ] && echo "$name" || echo "$alias")" \
        --arg token "$token" --arg url "$url" --arg model "$model" \
        --arg haiku "$haiku" --arg sonnet "$sonnet" --arg opus "$opus" \
        '{alias_name:$name, token:$token, url:$url, model:$model,
          small_fast_model:(if $haiku=="" then null else $haiku end),
          anthropic_default_sonnet_model:(if $sonnet=="" then null else $sonnet end),
          anthropic_default_opus_model:(if $opus=="" then null else $opus end)
         } | with_entries(select(.value != null))')

    local tmp
    tmp=$(mktemp)
    jq --arg a "$alias" --argjson e "$entry" '.configurations[$a] = $e' \
        "$CC_SWITCH_CONFIG" > "$tmp" && mv "$tmp" "$CC_SWITCH_CONFIG"
}

# Convert cc-switch Configuration format to plugin Provider format
# cc-switch: { "alias": { "alias_name": "...", "token": "...", "url": "...", ... } }
# plugin:    { "id": "alias", "name": "...", "auth_token": "...", "base_url": "...", ... }
ccswitch_to_provider() {
    local alias="$1"
    local config="$2"

    local name token url model small_fast_model sonnet opus haiku
    name=$(echo "$config" | jq -r '.alias_name // empty')
    token=$(echo "$config" | jq -r '.token // empty')
    url=$(echo "$config" | jq -r '.url // empty')
    model=$(echo "$config" | jq -r '.model // empty')
    small_fast_model=$(echo "$config" | jq -r '.small_fast_model // empty')
    sonnet=$(echo "$config" | jq -r '.anthropic_default_sonnet_model // empty')
    opus=$(echo "$config" | jq -r '.anthropic_default_opus_model // empty')
    haiku=$(echo "$config" | jq -r '.anthropic_default_haiku_model // empty')

    jq -n \
        --arg id "$alias" \
        --arg name "$name" \
        --arg token "$token" \
        --arg url "$url" \
        --arg model "$model" \
        --arg haiku "$small_fast_model" \
        --arg sonnet "$sonnet" \
        --arg opus "$opus" \
        '{
            id: $id,
            name: (if $name == "" then $id else $name end),
            auth_token: $token,
            base_url: $url,
            model: $model,
            haiku_model: (if $haiku == "" then null else $haiku end),
            sonnet_model: (if $sonnet == "" then null else $sonnet end),
            opus_model: (if $opus == "" then null else $opus end)
        }'
}

cmd_list() {
    if [ ! -f "$CC_SWITCH_CONFIG" ]; then
        echo '{"providers":[]}'
        return
    fi

    local configs
    configs=$(jq 'if .configurations then .configurations else {} end' "$CC_SWITCH_CONFIG" 2>/dev/null || echo '{}')

    local result='{"providers":[]}'
    local aliases
    aliases=$(echo "$configs" | jq -r 'keys[]' 2>/dev/null || echo '')

    if [ -z "$aliases" ]; then
        echo '{"providers":[]}'
        return
    fi

    local providers='[]'
    while IFS= read -r alias; do
        [ -z "$alias" ] && continue
        local config
        config=$(echo "$configs" | jq -r ".[\"$alias\"]" 2>/dev/null)
        [ "$config" = "null" ] && continue

        local provider
        provider=$(ccswitch_to_provider "$alias" "$config")
        providers=$(echo "$providers" | jq ". + [$provider]")
    done <<< "$aliases"

    echo "{\"providers\":$providers}"
}

cmd_current() {
    if [ ! -f "$CLAUDE_SETTINGS" ]; then
        echo '{}'
        return
    fi
    jq '.env // {}' "$CLAUDE_SETTINGS" 2>/dev/null || echo '{}'
}

cmd_switch() {
    local alias="$1"

    # Get config from cc-switch storage
    if [ ! -f "$CC_SWITCH_CONFIG" ]; then
        echo '{"error":"provider not found"}' >&2
        exit 1
    fi

    local config
    config=$(jq -r --arg alias "$alias" '.configurations[$alias] // empty' "$CC_SWITCH_CONFIG")
    if [ "$config" = "empty" ] || [ "$config" = "null" ]; then
        echo '{"error":"provider not found"}' >&2
        exit 1
    fi

    # Extract values
    local url token model small_fast_model sonnet opus
    url=$(echo "$config" | jq -r '.url // empty')
    token=$(echo "$config" | jq -r '.token // empty')
    model=$(echo "$config" | jq -r '.model // empty')
    small_fast_model=$(echo "$config" | jq -r '.small_fast_model // empty')
    sonnet=$(echo "$config" | jq -r '.anthropic_default_sonnet_model // empty')
    opus=$(echo "$config" | jq -r '.anthropic_default_opus_model // empty')

    # Build env object with all values
    local env_json
    env_json=$(jq -n \
        --arg url "$url" \
        --arg token "$token" \
        --arg model "$model" \
        --arg small_fast "$small_fast_model" \
        --arg sonnet "$sonnet" \
        --arg opus "$opus" \
        '{
            ANTHROPIC_BASE_URL: (if $url == "" then null else $url end),
            ANTHROPIC_API_KEY: (if $token == "" then null else $token end),
            ANTHROPIC_AUTH_TOKEN: (if $token == "" then null else $token end),
            ANTHROPIC_MODEL: (if $model == "" then null else $model end),
            ANTHROPIC_SMALL_FAST_MODEL: (if $small_fast == "" then null else $small_fast end),
            ANTHROPIC_DEFAULT_HAIKU_MODEL: (if $small_fast == "" then null else $small_fast end),
            ANTHROPIC_DEFAULT_SONNET_MODEL: (if $sonnet == "" then null else $sonnet end),
            ANTHROPIC_DEFAULT_OPUS_MODEL: (if $opus == "" then null else $opus end)
        } | with_entries(select(.value != null))')

    # Update settings.json, preserving other fields
    local tmp
    tmp=$(mktemp)
    if [ -f "$CLAUDE_SETTINGS" ]; then
        jq --argjson env "$env_json" '.env = $env' "$CLAUDE_SETTINGS" > "$tmp" && mv "$tmp" "$CLAUDE_SETTINGS"
    else
        jq -n --argjson env "$env_json" '{env: $env}' > "$tmp" && mv "$tmp" "$CLAUDE_SETTINGS"
    fi

    # Record usage stats
    mkdir -p "$(dirname "$STATS_FILE")"
    local now today
    now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    today=$(date -u +%Y-%m-%d)
    local stats_tmp
    stats_tmp=$(mktemp)
    if [ -f "$STATS_FILE" ]; then
        jq --arg id "$alias" --arg ts "$now" --arg date "$today" \
            '.[$id] = {
                switchCount: (((.[$id].switchCount // 0)) + 1),
                lastUsed: $ts,
                firstUsed: (.[$id].firstUsed // $ts),
                daily: ((.[$id].daily // {}) | .[$date] = ((.[$date] // 0) + 1))
            }' "$STATS_FILE" > "$stats_tmp" && mv "$stats_tmp" "$STATS_FILE"
    else
        jq -n --arg id "$alias" --arg ts "$now" --arg date "$today" \
            '{($id): {switchCount: 1, lastUsed: $ts, firstUsed: $ts, daily: {($date): 1}}}' \
            > "$stats_tmp" && mv "$stats_tmp" "$STATS_FILE"
    fi

    # Record switch history for token attribution
    local history_file="$DATA_DIR/switch_history.jsonl"
    local prev_alias=""
    if [ -f "$history_file" ]; then
        prev_alias=$(tail -1 "$history_file" | jq -r '.alias // empty' 2>/dev/null || echo "")
    fi
    echo "{\"timestamp\":\"$now\",\"alias\":\"$alias\",\"prev_alias\":\"$prev_alias\"}" >> "$history_file"
    # Trim to 90 days (keep last ~4000 lines as a reasonable limit)
    if [ "$(wc -l < "$history_file")" -gt 4000 ]; then
        local htmp
        htmp=$(mktemp)
        tail -4000 "$history_file" > "$htmp" && mv "$htmp" "$history_file"
    fi

    echo "{\"ok\":true,\"id\":\"$alias\"}"
}

cmd_add() {
    local json="$1"

    local name base_url auth_token model haiku sonnet opus
    name=$(echo "$json" | jq -r '.name // .id // "provider"')
    base_url=$(echo "$json" | jq -r '.base_url // empty')
    auth_token=$(echo "$json" | jq -r '.auth_token // empty')
    model=$(echo "$json" | jq -r '.model // empty')
    haiku=$(echo "$json" | jq -r '.haiku_model // empty')
    sonnet=$(echo "$json" | jq -r '.sonnet_model // empty')
    opus=$(echo "$json" | jq -r '.opus_model // empty')

    local alias
    alias=$(echo "$name" | tr -cd '[:alnum:]_-' | tr '[:upper:]' '[:lower:]' | head -c 30)
    [ -z "$alias" ] && alias="provider$(date +%s)"

    mkdir -p "$(dirname "$CC_SWITCH_CONFIG")"
    [ ! -f "$CC_SWITCH_CONFIG" ] && echo '{"configurations":{}}' > "$CC_SWITCH_CONFIG"

    # Avoid duplicate aliases
    local existing
    existing=$(jq -r --arg a "$alias" '.configurations[$a] // "not_found"' "$CC_SWITCH_CONFIG" 2>/dev/null)
    [ "$existing" != "not_found" ] && alias="${alias}-$(date +%s)"

    _write_entry "$alias" "$name" "$auth_token" "$base_url" "$model" "$haiku" "$sonnet" "$opus"
    echo "{\"ok\":true,\"id\":\"$alias\"}"
}

cmd_update() {
    local alias="$1"
    local json="$2"

    if [ ! -f "$CC_SWITCH_CONFIG" ]; then
        echo '{"error":"provider not found"}' >&2
        exit 1
    fi

    local existing
    existing=$(jq -r --arg a "$alias" '.configurations[$a] // empty' "$CC_SWITCH_CONFIG" 2>/dev/null)
    if [ -z "$existing" ] || [ "$existing" = "null" ]; then
        echo '{"error":"provider not found"}' >&2
        exit 1
    fi

    # Merge new values over existing config
    local name base_url auth_token model haiku sonnet opus
    name=$(echo "$json"     | jq -r '.name // empty')
    base_url=$(echo "$json" | jq -r '.base_url // empty')
    auth_token=$(echo "$json" | jq -r '.auth_token // empty')
    model=$(echo "$json"    | jq -r '.model // empty')
    haiku=$(echo "$json"    | jq -r '.haiku_model // empty')
    sonnet=$(echo "$json"   | jq -r '.sonnet_model // empty')
    opus=$(echo "$json"     | jq -r '.opus_model // empty')

    [ -z "$name" ]       && name=$(echo "$existing"       | jq -r '.alias_name // "'"$alias"'"')
    [ -z "$base_url" ]   && base_url=$(echo "$existing"   | jq -r '.url // empty')
    [ -z "$auth_token" ] && auth_token=$(echo "$existing" | jq -r '.token // empty')
    [ -z "$model" ]      && model=$(echo "$existing"      | jq -r '.model // empty')
    [ -z "$haiku" ]      && haiku=$(echo "$existing"      | jq -r '.small_fast_model // empty')
    [ -z "$sonnet" ]     && sonnet=$(echo "$existing"     | jq -r '.anthropic_default_sonnet_model // empty')
    [ -z "$opus" ]       && opus=$(echo "$existing"       | jq -r '.anthropic_default_opus_model // empty')

    _write_entry "$alias" "$name" "$auth_token" "$base_url" "$model" "$haiku" "$sonnet" "$opus"
    echo '{"ok":true}'
}

cmd_delete() {
    local alias="$1"

    if [ ! -f "$CC_SWITCH_CONFIG" ]; then
        echo '{"error":"provider not found"}' >&2
        exit 1
    fi

    local tmp
    tmp=$(mktemp)
    if jq --arg a "$alias" 'del(.configurations[$a])' "$CC_SWITCH_CONFIG" > "$tmp"; then
        mv "$tmp" "$CC_SWITCH_CONFIG"
        echo '{"ok":true}'
    else
        rm -f "$tmp"
        echo '{"error":"failed to delete provider"}' >&2
        exit 1
    fi
}

cmd_import() {
    if [ ! -f "$CLAUDE_SETTINGS" ]; then
        echo '{"error":"~/.claude/settings.json not found"}' >&2
        exit 1
    fi

    local env_json
    env_json=$(jq '.env // {}' "$CLAUDE_SETTINGS")

    local base_url auth_token model
    base_url=$(echo "$env_json" | jq -r '.ANTHROPIC_BASE_URL // empty')
    # Support both key names; cc-switch uses ANTHROPIC_AUTH_TOKEN, some setups use API_KEY
    auth_token=$(echo "$env_json" | jq -r '.ANTHROPIC_API_KEY // .ANTHROPIC_AUTH_TOKEN // empty')
    model=$(echo "$env_json" | jq -r '.ANTHROPIC_MODEL // empty')

    if [ -z "$auth_token" ]; then
        echo '{"error":"no API key in current config"}' >&2
        exit 1
    fi

    # Check for duplicates: same base_url AND auth_token
    # Normalize null URL to "" for comparison to handle configs saved without a base_url field
    if [ -f "$CC_SWITCH_CONFIG" ]; then
        local dup dup_name
        dup=$(jq -r --arg url "$base_url" --arg token "$auth_token" \
            '.configurations // {} | to_entries[] |
             select((.value.url // "") == $url and .value.token == $token) |
             .key' "$CC_SWITCH_CONFIG" | head -1)
        if [ -n "$dup" ]; then
            dup_name=$(jq -r --arg alias "$dup" '.configurations[$alias].alias_name // $alias' "$CC_SWITCH_CONFIG")
            echo "{\"error\":\"duplicate\",\"existing\":\"$dup\",\"existing_name\":\"$dup_name\"}" >&2
            exit 1
        fi
    fi

    local alias="imported-$(date +%Y%m%d-%H%M%S)"
    _write_entry "$alias" "$alias" "$auth_token" "$base_url" "$model" "" "" ""
    echo "{\"ok\":true,\"id\":\"$alias\"}"
}

cmd_next() {
    # Get current URL
    local current_url=""
    if [ -f "$CLAUDE_SETTINGS" ]; then
        current_url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$CLAUDE_SETTINGS" 2>/dev/null || echo "")
    fi

    # Get list of aliases
    if [ ! -f "$CC_SWITCH_CONFIG" ]; then
        echo '{"error":"no providers configured"}' >&2
        exit 1
    fi

    local aliases
    aliases=$(jq -r 'if .configurations then .configurations | keys[] else [] end' "$CC_SWITCH_CONFIG" 2>/dev/null)

    if [ -z "$aliases" ]; then
        echo '{"error":"no providers configured"}' >&2
        exit 1
    fi

    # Find current index
    local current_idx=-1
    local idx=0
    while IFS= read -r alias; do
        [ -z "$alias" ] && continue
        local url
        url=$(jq -r --arg alias "$alias" '.configurations[$alias].url // empty' "$CC_SWITCH_CONFIG")
        if [ "$url" = "$current_url" ]; then
            current_idx=$idx
        fi
        idx=$((idx + 1))
    done <<< "$aliases"

    # Get next alias
    local total=$idx
    local next_idx=$(( (current_idx + 1) % total ))
    local next_alias
    next_alias=$(echo "$aliases" | sed -n "$((next_idx + 1))p")

    cmd_switch "$next_alias"
}

