cmd_presets() {
    echo "{\"presets\":$PRESETS}"
}

cmd_preset_add() {
    local preset_id="$1"

    # Find preset
    local preset
    preset=$(echo "$PRESETS" | jq -r --arg id "$preset_id" '.[] | select(.id == $id)')
    if [ -z "$preset" ] || [ "$preset" = "null" ]; then
        echo '{"error":"preset not found"}' >&2
        exit 1
    fi

    local name base_url model haiku_model website
    name=$(echo "$preset" | jq -r '.name')
    base_url=$(echo "$preset" | jq -r '.base_url')
    model=$(echo "$preset" | jq -r '.model')
    haiku_model=$(echo "$preset" | jq -r '.haiku_model')
    website=$(echo "$preset" | jq -r '.website')

    # Ensure data directory exists
    mkdir -p "$(dirname "$CC_SWITCH_CONFIG")"

    # Create config storage if it doesn't exist
    if [ ! -f "$CC_SWITCH_CONFIG" ]; then
        echo '{"configurations":{}}' > "$CC_SWITCH_CONFIG"
    fi

    # Check if alias already exists
    local existing
    existing=$(jq -r --arg alias "$preset_id" '.configurations[$alias] // "not_found"' "$CC_SWITCH_CONFIG" 2>/dev/null || echo "error")
    if [ "$existing" != "not_found" ] && [ "$existing" != "error" ] && [ -n "$existing" ]; then
        echo '{"error":"provider already exists, please delete first or use a different name"}' >&2
        exit 1
    fi

    # Add preset directly to config (no token required for preset template)
    local tmp
    tmp=$(mktemp)
    jq --arg alias "$preset_id" \
       --arg alias_name "$name" \
       --arg url "$base_url" \
       --arg model "$model" \
       --arg small_fast "$haiku_model" \
       '.configurations[$alias] = {
           alias_name: $alias_name,
           token: "",
           url: $url,
           model: $model,
           small_fast_model: $small_fast
       }' \
       "$CC_SWITCH_CONFIG" > "$tmp" && mv "$tmp" "$CC_SWITCH_CONFIG"

    echo "{\"ok\":true,\"id\":\"$preset_id\",\"name\":\"$name\",\"base_url\":\"$base_url\",\"model\":\"$model\"}"
}

# ============ SPEEDTEST ============

cmd_speedtest() {
    local alias="${1:-}"

    if [ -n "$alias" ]; then
        # Test specific provider
        local config
        config=$(jq -r --arg alias "$alias" '.configurations[$alias] // empty' "$CC_SWITCH_CONFIG" 2>/dev/null)
        if [ "$config" = "empty" ] || [ "$config" = "null" ]; then
            echo '{"error":"provider not found"}' >&2
            exit 1
        fi

        local url token
        url=$(echo "$config" | jq -r '.url // empty')
        token=$(echo "$config" | jq -r '.token // empty')

        local result
        result=$(measure_latency "$url" "$token")
        echo "{\"alias\":\"$alias\",$result}"
    else
        # Test all providers
        if [ ! -f "$CC_SWITCH_CONFIG" ]; then
            echo '{"results":[]}'
            return
        fi

        local aliases
        aliases=$(jq -r 'if .configurations then .configurations | keys[] else [] end' "$CC_SWITCH_CONFIG" 2>/dev/null)

        local results='[]'
        while IFS= read -r a; do
            [ -z "$a" ] && continue
            local config url token
            config=$(jq -r --arg alias "$a" '.configurations[$alias]' "$CC_SWITCH_CONFIG" 2>/dev/null)
            url=$(echo "$config" | jq -r '.url // empty')
            token=$(echo "$config" | jq -r '.token // empty')

            local latency
            latency=$(measure_latency "$url" "$token")
            results=$(echo "$results" | jq ". + [{\"alias\":\"$a\",$latency}]")
        done <<< "$aliases"

        echo "{\"results\":$results}"
    fi
}

measure_latency() {
    local url="$1"
    local token="$2"

    if [ -z "$url" ]; then
        echo "\"latency\":null,\"error\":\"no url\""
        return
    fi

    # Test with curl, measure time to first byte
    local start end ms response_code
    start=$(python3 -c 'import time; print(int(time.time() * 1000))' 2>/dev/null) || start=$(date +%s%3N)

    # Try a simple models list request or ping
    response_code=$(curl -s -o /dev/null -w "%{http_code}" \
        --max-time 10 \
        -H "Authorization: Bearer $token" \
        -H "Content-Type: application/json" \
        "$url/models" 2>/dev/null || echo "000")

    end=$(python3 -c 'import time; print(int(time.time() * 1000))' 2>/dev/null) || end=$(date +%s%3N)
    ms=$((end - start))

    if [ "$response_code" = "200" ]; then
        echo "\"latency\":$ms,\"status\":\"ok\""
    elif [ "$response_code" = "401" ]; then
        echo "\"latency\":$ms,\"status\":\"auth_error\""
    elif [ "$response_code" = "404" ]; then
        # Try /v1/models
        local models_url="${url%/}/v1/models"
        response_code=$(curl -s -o /dev/null -w "%{http_code}" \
            --max-time 10 \
            -H "Authorization: Bearer $token" \
            "$models_url" 2>/dev/null || echo "000")
        if [ "$response_code" = "200" ]; then
            echo "\"latency\":$ms,\"status\":\"ok\""
        else
            echo "\"latency\":$ms,\"status\":\"endpoint_not_found\""
        fi
    else
        echo "\"latency\":null,\"status\":\"error\",\"code\":$response_code"
    fi
}

# ============ STATS ============

cmd_token_stats() {
    local days="${1:-7}"
    # Pass current alias so unattributed requests fall back to it (e.g. before history exists)
    local current_alias=""
    if [ -f "$CLAUDE_SETTINGS" ]; then
        local cur_url cur_token
        cur_url=$(jq -r '.env.ANTHROPIC_BASE_URL // empty' "$CLAUDE_SETTINGS" 2>/dev/null)
        cur_token=$(jq -r '.env.ANTHROPIC_API_KEY // .env.ANTHROPIC_AUTH_TOKEN // empty' "$CLAUDE_SETTINGS" 2>/dev/null)
        if [ -n "$cur_token" ] && [ -f "$CC_SWITCH_CONFIG" ]; then
            current_alias=$(jq -r --arg url "$cur_url" --arg token "$cur_token" \
                '.configurations // {} | to_entries[] |
                 select((.value.url // "") == $url and .value.token == $token) | .key' \
                "$CC_SWITCH_CONFIG" 2>/dev/null | head -1)
        fi
    fi
    python3 - "$DATA_DIR" "$days" "$HOME" "$current_alias" <<'PYEOF'
import sys, json, os, glob, bisect
from datetime import datetime, timezone, timedelta

data_dir, days_str, home_dir, fallback_alias = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4] if len(sys.argv) > 4 else ''
days = int(days_str)
now_ts = datetime.now(timezone.utc)
cutoff_ts = now_ts - timedelta(days=days)
cutoff_mtime = cutoff_ts.timestamp()

# --- Load switch history and build intervals ---
history_file = os.path.join(data_dir, 'switch_history.jsonl')
intervals = []  # list of (start_ts, end_ts_or_None, alias)

if os.path.exists(history_file):
    events = []
    with open(history_file) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                e = json.loads(line)
                ts = datetime.fromisoformat(e['timestamp'].replace('Z', '+00:00'))
                events.append((ts, e.get('alias', '')))
            except Exception:
                pass
    events.sort(key=lambda x: x[0])
    for i, (ts, alias) in enumerate(events):
        end = events[i + 1][0] if i + 1 < len(events) else None
        intervals.append((ts, end, alias))

# sort keys for bisect
interval_starts = [iv[0] for iv in intervals]

def find_alias_at(ts):
    idx = bisect.bisect_right(interval_starts, ts) - 1
    if idx < 0:
        return fallback_alias or None
    _, end, alias = intervals[idx]
    if end is not None and ts >= end:
        return fallback_alias or None
    return alias

def clean_project(name):
    # ~/.claude/projects paths look like -Users-foo-path-to-proj
    parts = name.lstrip('-').replace('-', '/', 2).rsplit('/', 1)
    return parts[-1].replace('-', '/') if len(parts) > 1 else name

# --- Scan recent project JSONL files ---
projects_dir = os.path.join(home_dir, '.claude', 'projects')
by_provider = {}   # alias -> {input, output, cache, requests}
daily = {}         # "YYYY-MM-DD" -> {input, output}
request_log = []   # list of dicts, collected then trimmed

if os.path.isdir(projects_dir):
    for proj in os.listdir(projects_dir):
        proj_path = os.path.join(projects_dir, proj)
        if not os.path.isdir(proj_path):
            continue
        for fname in os.listdir(proj_path):
            if not fname.endswith('.jsonl'):
                continue
            fpath = os.path.join(proj_path, fname)
            if os.path.getmtime(fpath) < cutoff_mtime:
                continue
            try:
                with open(fpath, encoding='utf-8', errors='ignore') as f:
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            obj = json.loads(line)
                        except Exception:
                            continue
                        msg = obj.get('message', {})
                        if not isinstance(msg, dict):
                            continue
                        usage = msg.get('usage')
                        if not usage:
                            continue
                        ts_str = obj.get('timestamp', '')
                        if not ts_str:
                            continue
                        try:
                            ts = datetime.fromisoformat(ts_str.replace('Z', '+00:00'))
                        except Exception:
                            continue
                        if ts < cutoff_ts:
                            continue
                        inp = int(usage.get('input_tokens', 0) or 0)
                        out = int(usage.get('output_tokens', 0) or 0)
                        cache = int((usage.get('cache_creation_input_tokens', 0) or 0) +
                                    (usage.get('cache_read_input_tokens', 0) or 0))
                        alias = find_alias_at(ts)
                        day_key = ts.date().isoformat()
                        # by_provider
                        if alias:
                            bp = by_provider.setdefault(alias, {'input': 0, 'output': 0, 'cache': 0, 'requests': 0})
                            bp['input'] += inp
                            bp['output'] += out
                            bp['cache'] += cache
                            bp['requests'] += 1
                        # daily totals
                        dv = daily.setdefault(day_key, {'input': 0, 'output': 0})
                        dv['input'] += inp
                        dv['output'] += out
                        # request log
                        request_log.append({
                            'ts': ts_str,
                            'alias': alias or '',
                            'project': clean_project(proj),
                            'input': inp,
                            'output': out,
                        })
            except Exception:
                pass

request_log.sort(key=lambda x: x['ts'], reverse=True)
request_log = request_log[:50]

print(json.dumps({'by_provider': by_provider, 'daily': daily, 'request_log': request_log}))
PYEOF
}

cmd_stats_reset() {
    local alias="${1:-}"
    if [ -n "$alias" ]; then
        if [ -f "$STATS_FILE" ]; then
            local tmp
            tmp=$(mktemp)
            jq --arg id "$alias" 'del(.[$id])' "$STATS_FILE" > "$tmp" && mv "$tmp" "$STATS_FILE"
        fi
    else
        rm -f "$STATS_FILE"
    fi
    echo '{"ok":true}'
}

cmd_stats() {
    if [ ! -f "$STATS_FILE" ]; then
        echo '{}'
        return
    fi
    cat "$STATS_FILE"
}

# Main
cmd="${1:-help}"
shift || true

case "$cmd" in
    list)          cmd_list ;;
    current)       cmd_current ;;
    switch)        cmd_switch "${1:?switch requires provider alias}" ;;
    add)           cmd_add "${1:?add requires json}" ;;
    update)        cmd_update "${1:?update requires alias}" "${2:?update requires json}" ;;
    delete)        cmd_delete "${1:?delete requires alias}" ;;
    import)        cmd_import ;;
    next)          cmd_next ;;
    presets)       cmd_presets ;;
    preset_add)    cmd_preset_add "${1:?preset_add requires preset id}" ;;
    speedtest)     cmd_speedtest "${1:-}" ;;
    stats)         cmd_stats ;;
    stats_reset)   cmd_stats_reset "${1:-}" ;;
    token_stats)   cmd_token_stats "${1:-7}" ;;
    help|*)
        echo '{"commands":["list","current","switch","add","update","delete","import","next","presets","preset_add","speedtest","stats","stats_reset","token_stats"]}'
        ;;
esac
